rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

// Usuários
    match /usuarios/{usuarioId} {
      allow read, write: if true;
    }

// Características para histórico
    match /caracteristicas/{caracteristicaId} {
      allow read, write: if true;
    }    


// Plantas
    match /plantas/{plantaID} {
      allow read, write: if true;
      match /medicoes/{medicaoId} {
    	  allow read, write: if true;
      }
    }
		// Plantas (estados)
		match /estados_planta/{estadoId} {
      allow read, write: if true;
    }
  	// Espécies
    match /especies/{especieId} {
      allow read, write: if true;
    }
			// Espécies (categorias)
      match /categorias_especies/{doc} {
        allow read, write: if true;
      }
			// Espécies (estagios)
      match /estagios_planta/{estagioId} {
        allow read, write: if true;
      }
	  // Variedades
    match /variedades/{variedadeId} {
      allow read, write: if true;
    }

	// Hortas
  match /hortas/{hortaId} {
    allow read, write: if true;
  }
	// Canteiros
  match /canteiros/{canteiroID} {
    allow read, write: if true;
  }
    // Canteiros (estados)
    match /estados_canteiro/{estadoId} {
      allow read, write: if true;
    }
	// Dispositivos
  match /dispositivos/{dispositivoId} {
	  allow read, write: if true;
  }


// Manejos
    match /manejos/{manejoId} {
      allow read, write: if true;
      match /efeitos/{paramentroId} {
      	allow read, write: if true;
      }
      match /entradas/{entradaId} {
      	allow read, write: if true;
      }
    }
// Eventos
    match /eventos/{eventoId} {
    	allow read, write: if true;
    }
    match /mutacoes/{mutacaoId} {
    	allow read, write: if true;
    }


// Tarefas
	//CV
		match /cvJobRuns/{jobRunId} {
    	allow read, write: if true;
    }
		match /cvJobSpecs/{jobSpecId} {
    	allow read, write: if true;
    }
    match /cvModelos/{modeloId} {
	    allow read, write: if true;
    }
	//Tarefa
		match /tarefas/{tarefaId} {
    	allow read, write: if true;
    }
	//Necessidades
	  match /necessidades/{entidadeId} {
    	allow read, write: if true;
    }
	//Mídia
		match /midias/{midiaId} {
    	allow read, write: if true;
    }
  }
}
