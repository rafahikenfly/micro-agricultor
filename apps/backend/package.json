{
  "name": "backend",
  "type": "module",
  "scripts": {
    "start": "node index.js",
    "job": "node index.js --job",
    "start:bg": "nohup node index.js > backend.log 2>&1 &",
    "stop:bg": "pkill -f index.js",
    "backendlog": "tail -f backend.log",
    "sensoreslog": "tail -f sensores.log",
    "updaterlog": "tail -f updater.log"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "firebase": "^8.10.1",
    "firebase-admin": "^13.7.0",
    "micro-agricultor": "file:../../packages/micro-agricultor",
    "mqtt": "^5.15.1",
    "node-cron": "^4.2.1"
  }
}
